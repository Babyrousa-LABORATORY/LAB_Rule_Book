{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://babyrousa_lab_master.org/animal_move",
    "title": "Animal Move Type",
    "description": "Type of special moves which is used as Animal Girls' instinctive skill.",
    "type":"object",
    "properties": {
        "id": {
            "type":"string",
            "pattern": "[a-z0-9_]"
        },
        "name": {
            "type":"string"
        },
        "skills": {
            "type": "array",
            "items": {
                "$ref": "https://babyrousa_lab_master.org/special_move",
                "properties": {
                    "trainCost": {
                        "type":"integer",
                        "minimum": 0
                    }
                }
            },
            "minItems": 0
        }
    }

}