{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/babyrousa_lab/specification/makeup",
    "title": "Makeup Specifications",
    "description": "体質の性能。体質の特性上、最低1種類は設定しなければならない。",
    "allOf": [
        {"$ref": "https://example.com/babyrousa_lab/specification"},
        {
            "properties": {
                "effect": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "minItems": 1,
                    "uniqueItems": true
                },
                "trigger": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "minItems": 1,
                    "uniqueItems": true
                }
            },
            "required": ["effect", "trigger"]
        }
    ]
}