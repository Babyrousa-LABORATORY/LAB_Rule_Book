                            },
                            "minItems": 1
                        },
                        "weakness": {
                            "type":"array",
                            "items": {
                                "type": "string"
                            },
                            "minItems": 1
                        },
                        "fatal": {
                            "type":"array",
                            "items": {
                                "type": "string"
                            },
                            "minItems": 1
