    "$id": "https://example.com/babyrousa_lab/specification/shield",
    "title": "Shield Specifications",
    "description": "アイテムの盾としての性能。",
    "allOf": [
        {"$ref": "https://example.com/babyrousa_lab/specification"},
        {
            "properties": {
