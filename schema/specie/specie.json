{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/babyrousa_lab/specie",
    "title": "Animal Girl Specie Type",
    "description": "アニマルガールの種族タイプを表す。研究員はかならずこれのなかから一つ選ばなければならない。使用可能なパッシブスキルやアニマルウェポンに影響する。",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "pattern": "[a-z0-9_]"
        },
        "name": {
            "type": "string",
            "minLength": 1
        },
        "init": {
            "$comment": "Initialize value of parameters",
            "type": "object",
            "property": {
                "hp": {
                    "type": "string"
                },
                "skill": {
                    "type": "string"
                },
                "strength": {
                    "type": "string"
                },
                "agility": {
                    "type": "string"
                },
                "magicPower": {
                    "type": "string"
                },
                "judgment": {
                    "type": "string"
                },
                "constitution": {
                    "type": "string"
                }
            },
            "required": ["hp","skill","strength","agility","magicPower","judgment","constitution"],
            "additionalProperties": {
                "type": "string"
            }
        },

        "growth": {
            "$comment": "dices of growth",
            "type": "object",
            "property": {
                "hp": {
                    "type": "string"
                },
                "skill": {
                    "type": "string"
                },
                "strength": {
                    "type": "string"
                },
                "agility": {
                    "type": "string"
                },
                "magicPower": {
                    "type": "string"
                },
                "judgment": {
                    "type": "string"
                },
                "constitution": {
                    "type": "string"
                }
            },
            "required": ["hp","skill","strength","agility","magicPower","judgment","constitution"],
            "additionalProperties": {
                "type": "string"
            }
        },
        "animalWeapon": {
            "description": "Default weapons of animal girl. This property will contains ID of animal weapon.",
            "type": "array",
            "items": {
                "type": "string"
            },
            "minItems": 1
        },
        "makeup": {
            "description": "Passive skills of animal girl. This property will contains ID of makeup",
            "type":"array",
            "items": {
                "type": "string"
            },
            "minItems": 1
        }
    }
}