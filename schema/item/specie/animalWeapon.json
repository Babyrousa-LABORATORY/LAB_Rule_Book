{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/babyrousa_lab/item/animal_weapon",
    "title": "Animal Weapon",
    "description": "アニマルガールにとっての「素手」。種族ごとに異なるほか、手放すことはできない。",
    "type":"object",
    "properties": {
        "id": {
            "type":"string",
            "pattern": "[a-z0-9_]",
            "minLength": 1
        },
        "name": {
            "type":"string",
            "minLength": 1
        },
        "detail": {
            "type": "string",
            "minLength": 1
        },
        "specification":{
            "$ref": "https://example.com/babyrousa_lab/specification/weapon"
        }
    },
    "required": ["specification"]
}